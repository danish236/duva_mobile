{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "backend",
    "main": "src/index.ts",
    "compatibility_date": "2026-06-21",
    "r2_buckets": [
        {
            "bucket_name": "duva-images",
            "binding": "duva_images",
            "remote": true
        }
    ]
}